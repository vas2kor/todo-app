APP_NAME=Collaborative Todo
APP_ENV=development
APP_DEBUG=false

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./todo.db
SESSION_SECRET=replace-this-secret
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:4173
ENABLE_HTTPS_REDIRECT=false
EXPOSE_TEST_OTP=true
OTP_RESEND_COOLDOWN_SECONDS=30

# OAuth
OAUTH_GOOGLE_CLIENT_ID=replace-me
OAUTH_GOOGLE_CLIENT_SECRET=replace-me
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:5500/

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_SOCKET_URL=http://localhost:8000
